# Configuration du Bot Solana Bollinger Bands
# Copiez ce fichier en .env et remplissez vos valeurs

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=votre_bot_token_ici
TELEGRAM_CHAT_ID=votre_chat_id_ici

# Monitoring Configuration
CHECK_FREQUENCY=30  # Fréquence de vérification en secondes (30 = toutes les 30s)

# Notes:
# - Obtenez votre Bot Token via @BotFather sur Telegram
# - Obtenez votre Chat ID via @userinfobot sur Telegram
# - Pour les vacances, augmentez CHECK_FREQUENCY à 60 ou 120 secondes
