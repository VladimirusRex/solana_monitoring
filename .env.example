# Copiez ce fichier en .env et remplissez avec vos vraies valeurs
# NE METTEZ JAMAIS vos vraies clés API dans ce fichier !

# Telegram
TELEGRAM_BOT_TOKEN=votre_token_telegram_ici
TELEGRAM_CHAT_ID=votre_chat_id_ici

# Birdeye API (optionnel)
BIRDEYE_API_KEY=votre_cle_birdeye_ici

# BitQuery API (recommandé - le plus fiable)
BITQUERY_TOKEN=votre_token_bitquery_ici
